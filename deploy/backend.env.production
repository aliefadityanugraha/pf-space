# =============================================================================
# PF Space Backend - Production Environment Variables
# =============================================================================
# CARA PAKAI:
#   cp .env.example .env
#   nano .env   (edit sesuai konfigurasi server kamu)
# =============================================================================

# -------------------------------------
# Server
# -------------------------------------
PORT=3000
HOST=0.0.0.0

# Penting untuk reverse proxy (Nginx)
# Aktifkan ini agar Better-Auth bisa membaca IP asli client
TRUST_PROXY=true

# -------------------------------------
# Database MySQL
# -------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=pfspace_user
DB_PASSWORD=ganti_dengan_password_kuat
DB_NAME=si_film_archive

# -------------------------------------
# Better Auth
# -------------------------------------
# Generate dengan: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=ganti_dengan_random_string_minimal_32_karakter

# URL backend yang diakses publik (pakai domain atau IP)
BETTER_AUTH_URL=https://yourdomain.com

# -------------------------------------
# Google OAuth (opsional)
# -------------------------------------
# Buat di: https://console.cloud.google.com/
# Authorized redirect URIs: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -------------------------------------
# Frontend URL
# -------------------------------------
# URL frontend yang diakses publik
FRONTEND_URL=https://yourdomain.com

# CORS (jika frontend dan backend beda domain)
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# -------------------------------------
# AI Provider
# -------------------------------------
AI_PROVIDER=gemini

# Groq (alternatif gratis)
# GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (direkomendasikan)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash-exp
GEMINI_EMBEDDING_MODEL=text-embedding-004

# OpenAI (opsional)
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini

# -------------------------------------
# Semantic Search
# -------------------------------------
USE_SEMANTIC_SEARCH=true
